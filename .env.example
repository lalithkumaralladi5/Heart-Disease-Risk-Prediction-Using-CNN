# Environment Configuration Example
# Copy this file to .env and fill in your values

# Application Settings
DEBUG=False
LOG_LEVEL=INFO

# Data Settings
DATA_PATH=./data/heart_disease.csv
RANDOM_SEED=42

# Model Settings
MODEL_PATH=./models/cnn_heart_model_pytorch.pth
SCALER_PATH=./models/scaler.pkl
BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=100

# Streamlit Settings
STREAMLIT_THEME_BASE=dark
STREAMLIT_THEME_PRIMARY_COLOR=#ff5f9e
